{
    "name": "multivendorx",
    "displayName": "MultiVendorX",
    "pluginSlug": "dc-woocommerce-multi-vendor",
    "description": "MultiVendorX - WooCommerce Multivendor Marketplace AI Powered Solutions",
    "version": "5.0.7",
    "license": "GPL-2.0-or-later",
    "author": "MultiVendorX",
    "homepage": "https://github.com/multivendorx/multivendorx#readme",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/multivendorx/multivendorx.git"
    },
    "bugs": {
        "url": "https://github.com/multivendorx/multivendorx/issues"
    },
    "main": "index.js",
    "mainPluginFile": "dc_product_vendor.php",
    "engines": {
        "node": "^22.22.3"
    },
    "scripts": {
        "build": "pnpm run build:project",
        "build:project": "pnpm --if-present \"/^build:project:.*$/\"",
        "build:project:bundle": "wireit",
        "build:release": "pnpm run version && pnpm run build:zip",
        "build:zip": "pnpm install && pnpm run readme && pnpm run build:project && pnpm run makepot && pnpm run makejson && pnpm run release",
        "watch": "pnpm run watch:build",
        "watch:build": "pnpm --if-present run \"/^watch:build:project:.*$/\"",
        "watch:build:project:bundle": "wireit",
        "watch:build:project:minify": "wireit",
        "lint": "pnpm run lint:js && pnpm run lint:css && pnpm run lint:php",
        "fix": "pnpm run fix:js && pnpm run fix:css && pnpm run fix:php",
        "lint:js": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs",
        "fix:js": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs --fix",
        "lint:css": "stylelint \"**/*.{css,scss}\"",
        "fix:css": "stylelint \"**/*.{css,scss}\" --fix",
        "lint:php": "composer run-script phpcs",
        "fix:php": "composer run-script phpfix",
        "test": "pnpm run test:php",
        "test:php": "./vendor/bin/phpunit -c phpunit.xml.dist",
        "env:create": "NODE_OPTIONS='--no-network-family-autoselection' pnpm wp-env start && pnpm run env:start:database",
        "env:start": "NODE_OPTIONS='--no-network-family-autoselection' pnpm wp-env start && pnpm run env:start:database",
        "env:start:database": "node ../../tools/scripts/docker-compose.mjs && docker compose up -d",
        "env:dev": "NODE_OPTIONS='--no-network-family-autoselection' pnpm wp-env start --update && pnpm run env:start:database && pnpm --if-present --filter storybook run watch:build:storybook",
        "env:stop": "pnpm wp-env stop && docker compose down",
        "env:restart": "NODE_OPTIONS='--no-network-family-autoselection' pnpm wp-env restart",
        "env:clean": "pnpm wp-env clean",
        "env:destroy": "pnpm wp-env destroy && rimraf docker-compose.yml",
        "readme": "wp-readme-to-md",
        "clean": "node ../../tools/scripts/clean.mjs",
        "minify": "node ../../tools/scripts/minify.mjs",
        "move": "node ../../tools/scripts/move-files.mjs",
        "release": "node ../../tools/scripts/release.mjs",
        "version": "node ../../tools/scripts/version-replace.mjs",
        "textdomain": "node ../../tools/scripts/update-textdomain.mjs",
        "changelog": "composer exec -- changelogger",
        "makepot": "pnpm exec wp i18n make-pot --domain='multivendorx' --include='assets/js,public, classes,templates,modules,config.php,dc_product_vendor.php' . --headers='{\"Report-Msgid-Bugs-To\":\"https://multivendorx.com/contact/\"}' --file-comment=\"Copyright (c) $(date +'%Y') MultiVendorX Inc. All Rights Reserved.\" languages/multivendorx.pot",
        "makejson": "pnpm exec wp i18n make-json languages --pretty-print --no-purge",
        "composer": "composer dump-autoload && composer update",
		"preinstall": "npx only-allow pnpm"
    },
    "wireit": {
        "build:project:bundle": {
            "command": "wp-scripts build --progress && pnpm run minify && pnpm run move && pnpm run clean",
            "files": [
                "src/**/*.{js,jsx,ts,tsx,scss}",
                "modules/**/*.{js,jsx,ts,tsx,scss}",
                "public/**/*",
                "webpack.config.js",
                "tsconfig.json"
            ],
            "output": [
                "assets/**"
            ],
            "clean": true
        },
        "watch:build:project:bundle": {
            "command": "wp-scripts start",
            "files": [
                "src/**/*.{js,jsx,ts,tsx,scss}",
                "modules/**/*.{js,jsx,ts,tsx,scss}",
                "public/**/*",
                "webpack.config.js",
                "tsconfig.json"
            ],
            "service": true
        },
        "watch:build:project:minify": {
            "command": "pnpm run minify",
            "files": [
                "src/**/*.{js,jsx,ts,tsx,scss}",
                "modules/**/*.{js,jsx,ts,tsx,scss}",
                "public/**/*"
            ]
        }
    },
    "dependencies": {
        "@emotion/react": "^11.14.0",
        "@emotion/styled": "^11.14.1",
        "@mui/material": "^9.0.1",
        "@react-pdf/renderer": "^4.5.1",
        "@stripe/connect-js": "^3.4.5",
        "@stripe/react-connect-js": "^3.4.3",
        "@tanstack/react-table": "^8.21.3",
        "@tinymce/tinymce-react": "^6.3.0",
        "@wordpress/data": "wp-6.6",
        "@wordpress/element": "wp-6.6",
        "@wordpress/hooks": "^4.46.0",
        "@wordpress/i18n": "wp-6.6",
        "@wordpress/react-i18n": "wp-6.6",
        "axios": "^1.16.1",
        "leaflet": "^1.9.4",
        "react": "19.2.6",
        "react-dom": "19.2.6",
        "react-router-dom": "^7.15.1",
        "react-select": "^5.10.2",
        "react-simple-maps": "^3.0.0",
        "recharts": "^3.8.1",
        "zyra": "workspace:*"
    }
}
