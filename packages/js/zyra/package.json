{
  "name": "zyra",
  "version": "1.0.0",
  "description": "Component library for WordPress plugins",
  "main": "./build/index.js",
  "module": "./build/index.js",
  "types": "./build/index.d.ts",
  "files": [
    "build"
  ],
  "exports": {
    ".": {
      "types": "./build/index.d.ts",
      "import": "./build/index.js",
      "require": "./build/index.js"
    },
    "./build/index.css": "./build/index.css"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "pnpm run lint:js && pnpm run lint:css",
    "fix": "pnpm run fix:js && pnpm run fix:css",
    "lint:js": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs",
    "fix:js": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs --fix",
    "lint:css": "stylelint \"**/*.{css,scss}\"",
    "fix:css": "stylelint \"**/*.{css,scss}\" --fix"
  },
  "dependencies": {
    "@react-pdf/renderer": "^4.5.1",
    "@tanstack/react-table": "^8.21.3",
    "axios": "^1.16.1",
    "react-modal": "^3.16.3",
    "zustand": "^5.0.13",
    "react-sortablejs": "^6.1.4",
    "react-multi-date-picker": "^4.5.2",
    "react-drag-listview": "^2.0.0",
    "@reactour/tour": "^3.7.0",
    "sortablejs": "^1.15.6"
  },
  "peerDependencies": {
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@reactour/tour": "^3.7.0",
    "@tinymce/tinymce-react": "^5.1.0",
    "google-map-react": "^2.2.1",
    "react": "18.3.x",
    "react-dom": "18.3.x",
    "react-drag-listview": "^2.0.0",
    "react-draggable": "^4.4.6",
    "react-multi-date-picker": "^4.5.2",
    "react-router-dom": "^7.5.0",
    "react-select": "^5.10.1",
    "react-sortablejs": "^6.1.4",
    "sortablejs": "^1.15.6"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "esbuild-sass-plugin": "^3.7.0",
    "sass": "^1.100.0",
    "tsup": "^8.5.1"
  }
}
