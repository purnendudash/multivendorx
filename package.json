{
  "name": "multivendorx",
  "version": "1.0.0",
  "private": true,
  "description": "MultiVendorX Monorepo",
  "homepage": "https://multivendorx.com/",
  "license": "GPL-2.0-or-later",
  "author": "MultiVendorX",
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": "^22.22.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/multivendorx"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "build:release": "pnpm -r --workspace-concurrency=1 run build:release",
    "build:zip": "pnpm -r --workspace-concurrency=1 run build:zip",
    "watch": "pnpm -r --parallel run watch",
    "dev": "pnpm -r --parallel run dev",
    "lint": "pnpm run lint:js && pnpm run lint:css && pnpm run lint:php",
    "lint:fix": "pnpm run fix:js && pnpm run fix:css && pnpm run fix:php",
    "lint:php": "pnpm -r --if-present run lint:php",
    "fix:php": "pnpm -r --if-present run fix:php",
    "lint:js": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs",
    "fix:js": "eslint . --ext .js,.jsx,.ts,.tsx,.mjs --fix",
    "lint:css": "stylelint \"plugins/**/*.{css,scss}\"",
    "fix:css": "stylelint \"plugins/**/*.{css,scss}\" --fix",
    "test": "pnpm -r run test",
    "clean": "rimraf -g \"**/node_modules\" \"**/vendor\" \"**/.wireit\" \"**/.cache\" \"**/release\" \"**/dist\"",
    "clean:build": "rimraf -g \"plugins/*/assets\" \"packages/*/build\"",
    "sync:deps": "syncpack fix-mismatches",
    "watch:storybook": "pnpm -r --workspace-concurrency=Infinity --stream \"/^watch:build:storybook.*$/\"",
    "composer:install": "composer install",
    "preinstall": "npx only-allow pnpm"
  },
  "devDependencies": {
    "@babel/core": "^7.27.1",
    "@eslint/js": "^9.28.0",
    "@storybook/addon-docs": "^10.1.10",
    "@storybook/react-vite": "^10.1.10",
    "@types/node": "^22.15.29",
    "@typescript-eslint/eslint-plugin": "^8.33.1",
    "@typescript-eslint/parser": "^8.33.1",
    "@wordpress/babel-preset-default": "^8.23.0",
    "@wordpress/dependency-extraction-webpack-plugin": "^6.31.0",
    "@wordpress/env": "10.23.x",
    "@wordpress/eslint-plugin": "^22.9.0",
    "@wordpress/prettier-config": "^4.23.0",
    "@wordpress/scripts": "^30.16.0",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.0.0",
    "chalk": "^5.4.1",
    "clean-css": "^5.3.3",
    "copy-webpack-plugin": "^13.0.0",
    "css-loader": "^7.1.2",
    "eslint": "^9.28.0",
    "fs-extra": "^11.3.0",
    "glob": "^11.0.2",
    "globals": "^16.2.0",
    "marked": "^18.0.5",
    "mini-css-extract-plugin": "^2.9.2",
    "postcss": "^8.5.3",
    "postcss-loader": "^8.1.1",
    "prettier": "^3.5.3",
    "replace-in-file": "^8.3.0",
    "rimraf": "^6.0.1",
    "sass": "^1.88.0",
    "sass-loader": "^16.0.5",
    "style-loader": "^4.0.0",
    "stylelint": "^16.19.1",
    "stylelint-config-standard-scss": "^15.0.1",
    "stylelint-scss": "^6.12.1",
    "syncpack": "^13.0.4",
    "terser": "^5.39.2",
    "ts-loader": "^9.5.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3",
    "webpack": "^5.105.0",
    "widdershins": "^4.0.1",
    "wireit": "^0.14.12",
    "wp-readme-to-markdown": "^1.0.1",
    "wp-textdomain": "^1.0.1"
  }
}